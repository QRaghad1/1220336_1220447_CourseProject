<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="8dp"
    android:background="#EEEEEE">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Manage Events"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#1F6F5F"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/etAdminTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Title *"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/etAdminCategory"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Category *"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/etAdminDate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Date * (yyyy-MM-dd)"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/etAdminTime"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Time"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/etAdminLocation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Location"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/etAdminSeats"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Seats"
        android:inputType="number"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/etAdminDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Description"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnAdminAddEvent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Add Event"
        android:backgroundTint="#1F6F5F"
        android:layout_marginBottom="16dp"/>

    <ListView
        android:id="@+id/listAdminEvents"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

</LinearLayout>